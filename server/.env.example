# Where the CubiCasa code + weights live (setup.sh puts them here)
CUBICASA_REPO=./CubiCasa5k
CUBICASA_WEIGHTS=./CubiCasa5k/model_best_val_loss_var.pkl

# Which website(s) may call this API (your Vite dev server; add prod domain later)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max image side (px) before running - keeps memory sane. GPU can go bigger.
MAX_SIDE_GPU=1024
MAX_SIDE_CPU=512

# --- PUBLIC DEPLOY (Cloudflare Tunnel + Vercel) — all three REQUIRED ---
# 1. Behind cloudflared every request reaches uvicorn from 127.0.0.1 (exempt
#    from rate limiting!). TRUST_PROXY=1 makes the limiter use the visitor's
#    real IP from CF-Connecting-IP / X-Forwarded-For.
TRUST_PROXY=0
# 2. Password for the /review dashboard (customer parse data — keep private).
#    Open as /review?token=<value>. Unset = localhost-only access.
REVIEW_TOKEN=
# 3. Add your Vercel prod domain to ALLOWED_ORIGINS above, comma-separated.

# --- LICENSE GATES (flip without touching code) ---
# CubiCasa weights: CC BY-NC (NON-commercial) | TF2DeepFloorplan: GPL-3.0 |
# SVD (Animate): Stability community license. Lawyer-check before charging.
DISABLE_CUBICASA=0
DISABLE_TF2=0
DISABLE_SVD=0

# One GPU, one queue: max simultaneous heavy GPU jobs (parse ML + renders
# SHARE this). Keep 1 on a 12 GB card.
MAX_CONCURRENT_GPU=1
# Size cap for /visualize screenshot + G-buffer uploads (MB)
MAX_RENDER_UPLOAD_MB=15

# --- Plan Doctor (self-checking agent; rules always run, free) ---
# Optional LLM second opinion: set BOTH to enable. Runs in parallel, never
# blocks a parse, never overrides the rules; writes to docs/LEARNINGS.md.
LLM_DOCTOR=0
ANTHROPIC_API_KEY=
# LLM_DOCTOR_MODEL=claude-haiku-4-5
# LEARNINGS_FILE=  (default: docs/LEARNINGS.md in the project)

# --- Supabase parse logging (OPTIONAL) ---
# Leave BOTH blank to disable logging entirely (default). To enable, create a
# Supabase project (see docs/SUPABASE.md), run schema.sql, then paste:
#   SUPABASE_URL = your project URL,  e.g. https://abcdxyz.supabase.co
#   SUPABASE_KEY = the SERVICE ROLE key (server-side only, NEVER in the frontend)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_TABLE=parses
